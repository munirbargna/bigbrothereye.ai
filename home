  document.getElementById('c-sp500').textContent = cSp.str; document.getElementById('c-sp500').className='ks '+cSp.cls;
  document.getElementById('c-ndx').textContent   = cNd.str; document.getElementById('c-ndx').className='ks '+cNd.cls;
  document.getElementById('c-oil').textContent   = cOi.str; document.getElementById('c-oil').className='ks '+cOi.cls;
  document.getElementById('c-gold').textContent  = cGo.str; document.getElementById('c-gold').className='ks '+cGo.cls;
  document.getElementById('c-silver').textContent= cSi.str; document.getElementById('c-silver').className='ks '+cSi.cls;

  // Big price boards
  document.getElementById('big-oil').textContent   = '$'+fmt(STATE.oil);
  document.getElementById('big-gold').textContent  = '$'+fmt(STATE.gold,0);
  document.getElementById('big-silver').textContent= '$'+fmt(STATE.silver);
  document.getElementById('oil-24h').textContent   = cOi.str;
  document.getElementById('gold-24h').textContent  = cGo.str;
  document.getElementById('silver-24h').textContent= cSi.str;

  // Ticker strip
  const tv = (id,v,d=2) => { const el=document.getElementById(id); if(el) el.textContent=fmt(v,d); };
  tv('t-sp500',STATE.sp500,0); tv('t-ndx',STATE.ndx,0); tv('t-vix',STATE.vix);
  tv('t-oil',STATE.oil); tv('t-gold',STATE.gold,0); tv('t-silver',STATE.silver);
