  const fmt = (v,d=2) => v.toLocaleString('en-US',{minimumFractionDigits:d,maximumFractionDigits:d});

  // KPI main values
  document.getElementById('v-sp500').textContent = fmt(STATE.sp500,0);
  document.getElementById('v-ndx').textContent   = fmt(STATE.ndx,0);
  document.getElementById('v-vix').textContent   = fmt(STATE.vix);
