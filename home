// Live trade objects
let ALL_TRADES = [];      // all whale trades
let MY_PORTFOLIO = [];    // trades user has copied
let CLOSED_TRADES = [];   // closed positions
let FOLLOWING = new Set();// whale IDs being followed
let wrChart = null;
let tradeIdCounter = 1000;
let realizedPnl = 0;

function randomWhale(){ return WHALE_PROFILES[Math.floor(Math.random()*WHALE_PROFILES.length)]; }
function randomAsset(){ return TRADE_ASSETS[Math.floor(Math.random()*TRADE_ASSETS.length)]; }
function randDir(whale){ 
  if(whale.bias==='LONG') return Math.random()<.75?'LONG':'SHORT';
  if(whale.bias==='SHORT') return Math.random()<.75?'SHORT':'LONG';
  return Math.random()<.5?'LONG':'SHORT';
}
function now_str(){
  const d=new Date();
  return d.toLocaleTimeString('it-IT',{hour:'2-digit',minute:'2-digit',second:'2-digit'});
}
function fmtMoney(v,d=2){ return (v>=0?'+':'')+v.toLocaleString('en-US',{minimumFractionDigits:d,maximumFractionDigits:d}); }

function generateTrade(){
  const whale = randomWhale();
  const asset = randomAsset();
  const dir   = randDir(whale);
  const entry = asset.basePrice();
  const size  = Math.round(rand(0.5,8.0)*10)/10;  // $M
  const id    = tradeIdCounter++;
  return { id, whale, asset, dir, entry, size,
    current: entry, pnl: 0, pnlPct: 0,
    status: 'OPEN', time: now_str(),
    isMyCopy: false, myEntry: 0,
    ttl: Math.floor(rand(3,18)) // ticks before possible close
  };
}

// Seed initial trades
function seedTrades(){
  for(let i=0;i<16;i++){
    const t = generateTrade();
    t.time = `${String(Math.floor(rand(14,21))).padStart(2,'0')}:${String(Math.floor(rand(0,59))).padStart(2,'0')}`;
    t.current = t.entry * (1 + rand(-0.02, 0.03));
    t.pnl = (t.current - t.entry) / t.entry * t.size * 1e6 / 1e3; // in $K shown as $M
    t.pnl = parseFloat((t.pnl * (t.dir==='SHORT'?-1:1)).toFixed(2));
    t.pnlPct = ((t.current - t.entry)/t.entry*100*(t.dir==='SHORT'?-1:1));
    t.ttl = Math.floor(rand(2,12));
    ALL_TRADES.unshift(t);
  }
}

// Tick: update existing + maybe add new + maybe close some
function tickEmulator(){
  const now = now_str();

  // Update current prices + PnL of open trades
  ALL_TRADES.forEach(t=>{
    if(t.status !== 'OPEN') return;
    t.ttl--;
    const move = t.asset.vol * rand(-1.5, 1.5);
    t.current = t.current * (1 + move);
    const raw = (t.current - t.entry) / t.entry;
    t.pnl = parseFloat((raw * t.size * (t.dir==='SHORT'?-1:1) * 100).toFixed(2)); // $K
    t.pnlPct = parseFloat((raw * 100 * (t.dir==='SHORT'?-1:1)).toFixed(2));

    // Update my copy PnL
    if(t.isMyCopy){
      const myRaw = (t.current - t.myEntry) / t.myEntry;
      t.myPnl = parseFloat((myRaw * t.size * (t.dir==='SHORT'?-1:1) * 100).toFixed(2));
      t.myPnlPct = parseFloat((myRaw * 100 * (t.dir==='SHORT'?-1:1)).toFixed(2));
    }

    // Close trade if ttl expired (simulate whale exit)
    if(t.ttl <= 0){
      // Whale win rate influences outcome
      const winProb = t.whale.wins / 100;
      const isWin = Math.random() < winProb;
      if(isWin && t.pnl < 0) t.pnl = Math.abs(t.pnl) * rand(0.5,1.5);
      if(!isWin && t.pnl > 0) t.pnl = -Math.abs(t.pnl) * rand(0.3,1.2);
      t.status = isWin ? 'WIN' : 'LOSS';
      t.closeTime = now;

      // If I was copying this
      if(t.isMyCopy){
        realizedPnl += (t.myPnl || t.pnl * 0.1);
        CLOSED_TRADES.unshift({...t, finalPnl: t.myPnl || t.pnl * 0.1});
        MY_PORTFOLIO = MY_PORTFOLIO.filter(p => p.id !== t.id);
      }

      // Update whale stats
      if(isWin) t.whale.wins = Math.min(95, t.whale.wins + 0.1);
      else       t.whale.losses = Math.min(95, t.whale.losses + 0.1);
    }
  });

  // Add new trade with 40% probability each tick
  if(Math.random() < 0.40){
    const nt = generateTrade();
    ALL_TRADES.unshift(nt);
    // Auto-follow: if user follows this whale, auto-add to portfolio
    if(FOLLOWING.has(nt.whale.id)){
      nt.isMyCopy = true;
      nt.myEntry = nt.entry;
      nt.myPnl = 0;
      nt.myPnlPct = 0;
      MY_PORTFOLIO.unshift(nt);
    }
  }

  // Keep feed capped
  if(ALL_TRADES.length > 80) ALL_TRADES = ALL_TRADES.slice(0,80);
  if(CLOSED_TRADES.length > 30) CLOSED_TRADES = CLOSED_TRADES.slice(0,30);

  renderEmulator();
}

function copyTrade(tradeId){
  const t = ALL_TRADES.find(x=>x.id===tradeId);
  if(!t || t.status!=='OPEN' || t.isMyCopy) return;
  t.isMyCopy = true;
  t.myEntry  = t.current;
  t.myPnl    = 0;
  t.myPnlPct = 0;
  MY_PORTFOLIO.unshift(t);
  renderEmulator();
}

function closePosition(tradeId){
  const t = ALL_TRADES.find(x=>x.id===tradeId);
  if(!t) return;
  t.isMyCopy = false;
  const closed = MY_PORTFOLIO.findIndex(x=>x.id===tradeId);
  if(closed !== -1){
    const ct = MY_PORTFOLIO[closed];
    realizedPnl += (ct.myPnl || 0);
    CLOSED_TRADES.unshift({...ct, finalPnl: ct.myPnl || 0, closeTime: now_str(), status: ct.myPnl >= 0 ? 'WIN':'LOSS'});
    MY_PORTFOLIO.splice(closed,1);
  }
  renderEmulator();
}

function closeAllPositions(){
  [...MY_PORTFOLIO].forEach(t=>closePosition(t.id));
}

function toggleFollow(whaleId, btn){
  if(FOLLOWING.has(whaleId)){
    FOLLOWING.delete(whaleId);
    btn.textContent = 'Copia segnali';
    btn.classList.remove('active');
    // Un-copy open positions of this whale
    MY_PORTFOLIO = MY_PORTFOLIO.filter(p=>{
      if(p.whale.id===whaleId){ p.isMyCopy=false; return false; }
      return true;
    });
  } else {
    FOLLOWING.add(whaleId);
    btn.textContent = '✓ Seguendo';
    btn.classList.add('active');
  }
  renderEmulator();
}

function renderEmulator(){
  const openTrades = ALL_TRADES.filter(t=>t.status==='OPEN');

  // ── KPI updates ──
  const avgWR = (WHALE_PROFILES.reduce((a,w)=>a+w.wins,0)/WHALE_PROFILES.length).toFixed(1);
  document.getElementById('emu-avg-wr').textContent = avgWR+'%';
  document.getElementById('emu-open-pos').textContent = openTrades.length;
  document.getElementById('feed-count').textContent = ALL_TRADES.length;

  // My PnL
  const unrealized = MY_PORTFOLIO.reduce((a,t)=>(a+(t.myPnl||0)),0);
  const totalPnl = realizedPnl + unrealized;
  const pnlEl = document.getElementById('emu-my-pnl');
  const prevPnl = parseFloat(pnlEl.dataset.prev||0);
  pnlEl.textContent = fmtMoney(totalPnl)+'K';
  pnlEl.className = 'pnl-counter '+(totalPnl>=0?'up':'dn');
  pnlEl.dataset.prev = totalPnl;
  if(Math.abs(totalPnl - prevPnl) > 0.01){
    pnlEl.style.animation='none'; void pnlEl.offsetWidth;
    pnlEl.style.animation = totalPnl>prevPnl ? 'priceUp .6s ease' : 'priceDn .6s ease';
  }
  document.getElementById('emu-my-pnl-pct').textContent = MY_PORTFOLIO.length+' pos. aperte · Real: '+fmtMoney(realizedPnl)+'K';
  document.getElementById('kpi-my-pnl').className = 'kpi '+(totalPnl>=0?'c-green':'c-red');

  // Top signal
  const topW = [...WHALE_PROFILES].sort((a,b)=>b.wins-a.wins)[0];
  const topAssetTrades = openTrades.filter(t=>t.whale.id===topW.id);
  if(topAssetTrades.length){
    const ta = topAssetTrades[0];
    document.getElementById('emu-top-signal').textContent = ta.asset.sym+' '+ta.dir;
    document.getElementById('emu-top-signal-wr').textContent = topW.name+' — '+topW.wins.toFixed(0)+'% WR';
  }

  // ── Whale profiles ──
  const grid = document.getElementById('whaleProfileGrid');
  grid.innerHTML = WHALE_PROFILES.map(w=>{
    const wt = ALL_TRADES.filter(t=>t.whale.id===w.id && t.status==='OPEN');
    const wr = w.wins.toFixed(1);
    const wrColor = w.wins>=75?'var(--accent)':w.wins>=65?'var(--amber)':'var(--red)';
    const isFollowing = FOLLOWING.has(w.id);
    const myPnlFromW = MY_PORTFOLIO.filter(p=>p.whale.id===w.id).reduce((a,t)=>a+(t.myPnl||0),0);
    return `<div class="we-card ${isFollowing?'selected':''}">
      <div class="we-head">
        <div>
          <div class="we-name">${w.emoji} ${w.name}</div>
          <div class="we-style">${w.style}</div>
        </div>
        <div style="text-align:right">
          <div style="font-family:var(--sans);font-weight:800;font-size:20px;color:${wrColor}">${wr}%</div>
          <div style="font-size:9px;color:var(--text3)">win rate</div>
        </div>
      </div>
      <div class="we-body">
        <div style="font-size:9px;color:var(--text3);margin-bottom:3px">Win rate — 90 giorni</div>
        <div class="wr-track"><div class="wr-fill" style="width:${wr}%;background:${wrColor}"></div></div>
        <div class="wr-label"><span>${w.losses.toFixed(0)}% loss</span><span>${wr}% win</span></div>
        <div class="we-stats">
          <div class="we-stat"><div class="we-stat-v">${w.aum}</div><div class="we-stat-l">AUM</div></div>
          <div class="we-stat"><div class="we-stat-v">${wt.length}</div><div class="we-stat-l">Open</div></div>
          <div class="we-stat"><div class="we-stat-v" style="color:${myPnlFromW>=0?'var(--accent)':'var(--red)'};font-size:11px">${fmtMoney(myPnlFromW,1)}K</div><div class="we-stat-l">Mio P&L</div></div>
        </div>
        <button class="copy-btn ${isFollowing?'active':''}" onclick="toggleFollow('${w.id}',this)">${isFollowing?'✓ Seguendo':'Copia segnali'}</button>
      </div>
    </div>`;
  }).join('');

  // ── Trade feed ──
  const feed = document.getElementById('tradeFeed');
  const rows = ALL_TRADES.slice(0,40).map(t=>{
    const pnlCls = t.pnl>=0?'up':'dn';
    const statusBadge = t.status==='OPEN'
      ? `<span class="b b-b" style="font-size:8px">OPEN</span>`
      : t.status==='WIN'
        ? `<span class="b b-g" style="font-size:8px">WIN</span>`
        : `<span class="b b-r" style="font-size:8px">LOSS</span>`;
    const dirBadge = t.dir==='LONG'
      ? `<span class="b b-g" style="font-size:8px">▲ L</span>`
      : `<span class="b b-r" style="font-size:8px">▼ S</span>`;
    const copyBtn = t.status==='OPEN' && !t.isMyCopy
      ? `<button class="copy-mini" onclick="copyTrade(${t.id})">COPIA</button>`
      : t.isMyCopy
        ? `<button class="copy-mini done" disabled>✓</button>`
        : '';
    return `<div class="tf-row ${t.isMyCopy?'my-copy':''} ${t.status==='OPEN'&&(ALL_TRADES.indexOf(t)===0)?'new-trade':''}">
      <span class="tf-time">${t.time}</span>
      <span class="tf-whale" style="color:${t.whale.color}">${t.whale.emoji} ${t.whale.id}</span>
      <span class="tf-asset">${t.asset.sym}</span>
      <span class="tf-dir">${dirBadge}</span>
      <span class="tf-entry">$${t.entry.toFixed(t.entry>100?1:2)}</span>
      <span class="tf-size">$${t.size.toFixed(1)}M</span>
      <span class="tf-pnl ${pnlCls}">${fmtMoney(t.pnl,1)}K</span>
      <span class="tf-status">${statusBadge}</span>
      <span class="tf-copy">${copyBtn}</span>
    </div>`;
  }).join('');
  feed.innerHTML = rows;

  // ── My portfolio ──
  const pf = document.getElementById('myPortfolio');
  if(MY_PORTFOLIO.length === 0){
    pf.innerHTML = '<div style="padding:24px;text-align:center;font-size:11px;color:var(--text3)">Nessuna posizione aperta</div>';
  } else {
    pf.innerHTML = MY_PORTFOLIO.map(t=>{
      const mp = t.myPnl||0, mpp = t.myPnlPct||0;
      const cls = mp>=0?'up':'dn';
      return `<div class="my-pf-row">
        <span class="pf-asset">${t.asset.sym}</span>
        <span class="pf-dir">${t.dir==='LONG'?'<span class="b b-g" style="font-size:8px">▲ L</span>':'<span class="b b-r" style="font-size:8px">▼ S</span>'}</span>
        <span class="pf-entry" title="Entry">$${t.myEntry.toFixed(t.myEntry>100?1:2)}</span>
        <span class="pf-current ${t.current>t.myEntry?'up':'dn'}">$${t.current.toFixed(t.current>100?1:2)}</span>
        <span class="pf-pnl ${cls}">${fmtMoney(mp,1)}K <span class="pf-pnlpct">(${mpp>=0?'+':''}${mpp.toFixed(2)}%)</span></span>
        <span class="pf-whale">${t.whale.emoji} ${t.whale.name}</span>
        <button class="pf-close" onclick="closePosition(${t.id})">✕</button>
      </div>`;
    }).join('');
  }

  // Realized + closed count
  document.getElementById('closed-count').textContent = CLOSED_TRADES.length;
  document.getElementById('realized-pnl').textContent = fmtMoney(realizedPnl,1)+'K';
  document.getElementById('realized-pnl').className = realizedPnl>=0?'up':'dn';

  // ── Closed log ──
  const cl = document.getElementById('closedLog');
  if(CLOSED_TRADES.length === 0){
    cl.innerHTML = '<div style="padding:16px;text-align:center;font-size:10px;color:var(--text3)">Nessuna trade chiusa ancora</div>';
  } else {
    cl.innerHTML = CLOSED_TRADES.slice(0,20).map(t=>{
      const fp = t.finalPnl||0;
      const cls = fp>=0?'up':'dn';
      return `<div class="closed-row">
        <span style="color:${t.whale.color};width:25px">${t.whale.emoji}</span>
        <span style="width:55px;font-weight:700;color:#fff">${t.asset.sym}</span>
        <span style="width:35px">${t.dir==='LONG'?'<span class="b b-g" style="font-size:8px">L</span>':'<span class="b b-r" style="font-size:8px">S</span>'}</span>
        <span style="flex:1;color:var(--text3)">${t.closeTime||t.time}</span>
        <span class="${cls}" style="font-weight:700;width:70px;text-align:right">${fmtMoney(fp,1)}K</span>
        <span style="width:40px;text-align:right">${t.status==='WIN'?'<span class="b b-g" style="font-size:8px">WIN</span>':'<span class="b b-r" style="font-size:8px">LOSS</span>'}</span>
      </div>`;
    }).join('');
  }

  // ── Leaderboard ──
  const sorted = [...WHALE_PROFILES].sort((a,b)=>b.wins-a.wins);
  const rankColors = ['gold-rank','silver-rank','bronze-rank'];
  const lb = document.getElementById('leaderboard');
  lb.innerHTML = sorted.map((w,i)=>{
    const wr = w.wins.toFixed(1);
    const wrColor = w.wins>=75?'var(--accent)':w.wins>=65?'var(--amber)':'var(--red)';
    return `<div class="leaderboard-row">
      <div class="lb-rank ${rankColors[i]||''}">${i+1}</div>
      <div style="flex:1">
        <div class="lb-name">${w.emoji} ${w.name}</div>
        <div style="font-size:9px;color:var(--text3)">${w.style} · ${w.aum}</div>
      </div>
      <div class="lb-wr">
        <div style="font-family:var(--sans);font-weight:700;font-size:15px;color:${wrColor}">${wr}%</div>
        <div class="wr-track" style="margin-top:3px"><div class="wr-fill" style="width:${wr}%;background:${wrColor}"></div></div>
      </div>
      <div class="lb-trades" style="color:var(--text3)">${w.trades} trade</div>
      <div class="lb-pnl ${w.pnl>=0?'up':'dn'}">${fmtMoney(w.pnl,1)}M</div>
    </div>`;
  }).join('');

  // ── Signal matrix (convergence) ──
  const assetSignals = {};
  openTrades.forEach(t=>{
    if(!assetSignals[t.asset.sym]) assetSignals[t.asset.sym]={long:0,short:0,whales:[]};
    if(t.dir==='LONG') assetSignals[t.asset.sym].long++;
    else assetSignals[t.asset.sym].short++;
    if(!assetSignals[t.asset.sym].whales.includes(t.whale.id))
      assetSignals[t.asset.sym].whales.push(t.whale.id);
  });
  const sorted_assets = Object.entries(assetSignals)
    .sort((a,b)=>(b[1].long+b[1].short)-(a[1].long+a[1].short))
    .slice(0,10);

  const sm = document.getElementById('signalMatrix');
  sm.innerHTML = sorted_assets.map(([sym,sig])=>{
    const total = sig.long + sig.short;
    const longPct = total>0?(sig.long/total*100).toFixed(0):50;
    const dominant = sig.long >= sig.short ? 'LONG' : 'SHORT';
    const domColor = dominant==='LONG'?'var(--accent)':'var(--red)';
    const convergence = sig.whales.length;
    const strength = Math.min(100, convergence * 20 + total * 8);
    return `<div class="signal-row">
      <span class="signal-label"><strong style="color:#fff">${sym}</strong> <span style="color:${domColor};font-size:9px">${dominant}</span></span>
      <div class="signal-track">
        <div class="signal-fill" style="width:${strength}%;background:linear-gradient(90deg,${domColor},${domColor}88)"></div>
      </div>
      <span style="width:35px;text-align:right;font-size:9px;font-weight:700;color:${domColor}">${strength.toFixed(0)}%</span>
      <span style="width:60px;text-align:right;font-size:9px;color:var(--text3)">${convergence} whale${convergence>1?'s':''}</span>
    </div>`;
  }).join('');

  // ── Win rate chart update ──
  if(wrChart){
    wrChart.data.datasets.forEach((ds,i)=>{
      const w = WHALE_PROFILES[i];
      if(w){ ds.data.push(parseFloat(w.wins.toFixed(1))); if(ds.data.length>20) ds.data.shift(); }
    });
    wrChart.data.labels.push(now_str()); if(wrChart.data.labels.length>20) wrChart.data.labels.shift();
    wrChart.update('none');
  }
}

function initWrChart(){
  const c = document.getElementById('c-wr-chart'); if(!c) return;
  const labels = Array.from({length:10},(_,i)=>'');
  wrChart = new Chart(c,{
    type:'line',
    data:{
      labels,
      datasets: WHALE_PROFILES.map(w=>({
        label: w.emoji+' '+w.id,
        data: Array.from({length:10},()=>w.wins+rand(-1,1)),
        borderColor: w.color,
        backgroundColor: w.color+'22',
        tension:.4, fill:false, pointRadius:1, borderWidth:1.5
      }))
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{legend:{display:true,labels:{boxWidth:8,font:{size:9},color:DT}}},
      scales:{
        x:{display:false},
        y:{min:50,max:95,grid:{color:DG},ticks:{color:DT,font:{size:9}}}
      },
      animation:{duration:0}
    }
  });
}

// Hook into existing 10s ticker
const _origTickPrices = tickPrices;
tickPrices = function(){
  _origTickPrices();
  tickEmulator();
};

// Init emulator when tab is opened
document.querySelector('.nb[onclick*="emulator"]').addEventListener('click',()=>{
  if(ALL_TRADES.length === 0){
    seedTrades();
    renderEmulator();
    setTimeout(initWrChart, 100);
  }
});

</script>
</body>
</html>
