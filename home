    ctx.beginPath(); ctx.moveTo(...px(lon,85)); ctx.lineTo(...px(lon,-85)); ctx.stroke();
  }
  for(let lat=60;lat>=-60;lat-=30){
    ctx.beginPath(); ctx.moveTo(...px(-180,lat)); ctx.lineTo(...px(180,lat)); ctx.stroke();
  }
  // equator highlight
