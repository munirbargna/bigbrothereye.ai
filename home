function initMap(){
  mapCanvas = document.getElementById('vesselMap');
  if(!mapCanvas) return;
  mapCtx = mapCanvas.getContext('2d');
  // Set resolution
  const dpr = window.devicePixelRatio||1;
  const w = mapCanvas.parentElement.clientWidth;
  mapCanvas.width = w * dpr;
  mapCanvas.height = 380 * dpr;
  mapCanvas.style.width = w+'px';
  mapCanvas.style.height = '380px';
  mapCtx.scale(dpr, dpr);
  mapCanvas._w = w;
  mapCanvas._h = 380;
  drawMap();

  mapCanvas.addEventListener('mousemove', (e)=>{
    const rect=mapCanvas.getBoundingClientRect();
    const mx=(e.clientX-rect.left)/mapCanvas._w;
    const my=(e.clientY-rect.top)/mapCanvas._h;
    let found=null;
    VESSELS.forEach(v=>{
      const dx=Math.abs(v.x-mx), dy=Math.abs(v.y-my);
      if(dx<0.025 && dy<0.025) found=v;
    });
    hoveredVessel=found;
    const tt=document.getElementById('mapTooltip');
    if(found){
      tt.style.display='block';
      tt.style.left=(e.clientX-rect.left+12)+'px';
      tt.style.top=(e.clientY-rect.top-10)+'px';
      const sc=found.status==='BLOCCATA'||found.status==='DEVIATA'?'color:var(--red)':'color:var(--accent)';
      tt.innerHTML=`<strong style="color:#fff">${found.id}</strong><br>${found.name}<br><span style="${sc}">${found.status}</span><br>Cargo: ${found.cargo}<br>Origine: ${found.origin}<br>Dest: ${found.dest}<br>Stazza: ${found.tons}`;
    } else { tt.style.display='none'; }
  });
  mapCanvas.addEventListener('mouseleave',()=>{ document.getElementById('mapTooltip').style.display='none'; hoveredVessel=null; });
}

function drawMap(){
  if(!mapCtx) return;
  const W=mapCanvas._w, H=mapCanvas._h;
  const ctx=mapCtx;
  ctx.clearRect(0,0,W,H);

  // px(lon,lat) → canvas pixel
  function px(lon,lat){ return [(lon+180)/360*W, (90-lat)/180*H]; }

  // Draw a polygon from array of [lon,lat] pairs
  function poly(pts, fill, stroke, lw=0.5){
    ctx.beginPath();
    ctx.moveTo(...px(...pts[0]));
    for(let i=1;i<pts.length;i++) ctx.lineTo(...px(...pts[i]));
    ctx.closePath();
    if(fill){ ctx.fillStyle=fill; ctx.fill(); }
    if(stroke){ ctx.strokeStyle=stroke; ctx.lineWidth=lw; ctx.stroke(); }
  }

  // ── OCEAN ──
  ctx.fillStyle='#07121a';
  ctx.fillRect(0,0,W,H);

  // ── GRID (lat/lon lines) ──
  ctx.strokeStyle='rgba(20,42,55,.9)'; ctx.lineWidth=.4;
