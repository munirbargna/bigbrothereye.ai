<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ILT Market Intelligence v3 — Live</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root{--bg:#060a0d;--bg2:#0c1318;--bg3:#101a20;--bg4:#152229;--border:#1a2b35;--border2:#223545;--text:#c0d4de;--text2:#6e8ea0;--text3:#334e5e;--accent:#00e5a0;--amber:#f5a623;--red:#ff3d5a;--blue:#29b6f6;--purple:#b39ddb;--gold:#ffd54f;--silver:#b0bec5;--crude:#ef6c00;--mono:'Space Mono',monospace;--sans:'Syne',sans-serif}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--mono);font-size:12px;line-height:1.6;overflow-x:hidden}
body::after{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,.04) 3px,rgba(0,0,0,.04) 4px);pointer-events:none;z-index:999}

/* ── LAYOUT ── */
.wrap{max-width:1400px;margin:0 auto;padding:0 20px 80px;position:relative;z-index:1}

/* ── HEADER ── */
header{border-bottom:1px solid var(--border);padding:14px 0 12px;margin-bottom:24px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;position:sticky;top:0;background:var(--bg);z-index:100}
.logo{font-family:var(--sans);font-weight:800;font-size:18px;display:flex;align-items:center;gap:8px}
.logo-icon{width:28px;height:28px;background:var(--accent);border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:11px;color:#000;font-weight:700}
.logo span{color:var(--accent)}
.header-meta{display:flex;align-items:center;gap:16px;font-size:10px;color:var(--text2)}
.live-pill{display:flex;align-items:center;gap:5px;background:rgba(0,229,160,.1);border:1px solid rgba(0,229,160,.3);padding:3px 9px;border-radius:20px;color:var(--accent);font-size:10px}
.live-dot{width:6px;height:6px;background:var(--accent);border-radius:50%;animation:pulse 1.4s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(0,229,160,.5)}60%{opacity:.7;box-shadow:0 0 0 5px transparent}}
.update-clock{color:var(--text3);font-size:10px}

/* ── LIVE TICKER STRIP ── */
.ticker-strip{background:var(--bg2);border-top:1px solid var(--border);border-bottom:1px solid var(--border);overflow:hidden;height:32px;display:flex;align-items:center;margin-bottom:20px}
.ticker-inner{display:flex;gap:0;animation:scroll-left 60s linear infinite;white-space:nowrap}
@keyframes scroll-left{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.tick-item{padding:0 24px;border-right:1px solid var(--border);font-size:11px;display:flex;align-items:center;gap:8px;height:32px}
.tick-name{color:var(--text3);letter-spacing:.06em}
.tick-val{font-weight:700;color:#fff}
.tick-chg{font-size:10px}

/* ── NAV ── */
nav{display:flex;gap:0;margin-bottom:28px;border:1px solid var(--border);border-radius:7px;overflow:hidden;width:fit-content;flex-wrap:wrap}
.nb{padding:7px 16px;background:none;border:none;color:var(--text2);font-family:var(--mono);font-size:10px;cursor:pointer;letter-spacing:.07em;text-transform:uppercase;border-right:1px solid var(--border);transition:all .18s}
.nb:last-child{border-right:none}
.nb:hover{background:var(--bg3);color:var(--text)}
.nb.active{background:var(--accent);color:#000;font-weight:700}

/* ── ALERT BAR ── */
.alert{border-left:3px solid var(--amber);background:rgba(245,166,35,.07);padding:10px 14px;border-radius:0 6px 6px 0;margin-bottom:20px;font-size:11px;color:var(--text)}
.alert strong{color:var(--amber)}
.alert-red{border-left-color:var(--red);background:rgba(255,61,90,.07)}
.alert-red strong{color:var(--red)}
.alert-blue{border-left-color:var(--blue);background:rgba(41,182,246,.07)}
.alert-blue strong{color:var(--blue)}

/* ── KPI GRID ── */
.kpi4{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:20px}
.kpi6{display:grid;grid-template-columns:repeat(6,1fr);gap:8px;margin-bottom:20px}
.kpi{background:var(--bg2);border:1px solid var(--border);border-radius:7px;padding:13px 15px;position:relative;overflow:hidden;transition:border-color .3s}
.kpi.flash{border-color:rgba(0,229,160,.6);transition:none}
.kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:2px}
.kpi.c-green::before{background:var(--accent)}
.kpi.c-red::before{background:var(--red)}
.kpi.c-amber::before{background:var(--amber)}
.kpi.c-blue::before{background:var(--blue)}
.kpi.c-gold::before{background:var(--gold)}
.kpi.c-silver::before{background:var(--silver)}
.kpi.c-crude::before{background:var(--crude)}
.kl{font-size:9px;color:var(--text3);letter-spacing:.09em;text-transform:uppercase;margin-bottom:6px}
.kv{font-family:var(--sans);font-weight:700;font-size:22px;color:#fff;line-height:1;transition:color .3s}
.ks{font-size:10px;margin-top:4px}
.up{color:var(--accent)}.dn{color:var(--red)}.neu{color:var(--amber)}

/* ── GRIDS ── */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:14px}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:14px}
.g-wide{display:grid;grid-template-columns:2fr 1fr;gap:14px;margin-bottom:14px}
.g-wide2{display:grid;grid-template-columns:1fr 2fr;gap:14px;margin-bottom:14px}

/* ── CARDS ── */
.card{background:var(--bg2);border:1px solid var(--border);border-radius:7px;padding:16px 18px;margin-bottom:14px}
.ct{font-size:9px;color:var(--text3);letter-spacing:.1em;text-transform:uppercase;margin-bottom:12px;display:flex;align-items:center;gap:5px}
.ct::before{content:'//';color:var(--accent)}

/* ── SECTION ── */
.sec{display:none}.sec.active{display:block}
@keyframes fi{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
.fi{animation:fi .35s ease forwards}

/* ── TABLES ── */
.dt{width:100%;border-collapse:collapse;font-size:11px}
.dt th{font-size:9px;color:var(--text3);letter-spacing:.08em;text-transform:uppercase;text-align:left;padding:5px 8px;border-bottom:1px solid var(--border)}
.dt td{padding:8px 8px;border-bottom:1px solid var(--border);color:var(--text);vertical-align:middle}
.dt tr:last-child td{border-bottom:none}
.dt tr:hover td{background:rgba(255,255,255,.02)}

/* ── BADGES ── */
.b{display:inline-block;padding:2px 6px;border-radius:3px;font-size:9px;font-weight:700;letter-spacing:.04em}
.b-g{background:rgba(0,229,160,.15);color:var(--accent);border:1px solid rgba(0,229,160,.3)}
.b-r{background:rgba(255,61,90,.15);color:var(--red);border:1px solid rgba(255,61,90,.3)}
.b-a{background:rgba(245,166,35,.15);color:var(--amber);border:1px solid rgba(245,166,35,.3)}
.b-b{background:rgba(41,182,246,.15);color:var(--blue);border:1px solid rgba(41,182,246,.3)}
.b-x{background:rgba(255,255,255,.07);color:var(--text2);border:1px solid var(--border)}
.b-gold{background:rgba(255,213,79,.15);color:var(--gold);border:1px solid rgba(255,213,79,.3)}

/* ── PROGRESS BARS ── */
.pr-row{display:flex;align-items:center;gap:8px;margin-bottom:7px;font-size:11px}
.pr-label{width:105px;color:var(--text2);flex-shrink:0;font-size:10px}
.pr-track{flex:1;height:5px;background:var(--bg3);border-radius:3px;overflow:hidden}
.pr-fill{height:100%;border-radius:3px;transition:width .6s ease}
.pr-val{width:60px;text-align:right;font-weight:700;font-size:10px}

/* ── METER ── */
.meter-track{height:8px;border-radius:4px;background:linear-gradient(90deg,var(--red),var(--amber),var(--accent));position:relative;margin-bottom:5px}
.meter-needle{position:absolute;top:-4px;width:3px;height:16px;background:#fff;border-radius:2px;transform:translateX(-50%);box-shadow:0 0 5px rgba(255,255,255,.5)}

/* ── COMMODITY PRICE BOARD ── */
.price-board{background:var(--bg2);border:1px solid var(--border);border-radius:7px;overflow:hidden;margin-bottom:14px}
.pb-header{background:var(--bg3);padding:10px 16px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border)}
.pb-title{font-family:var(--sans);font-weight:700;font-size:15px}
.pb-body{padding:14px 16px}
.big-price{font-family:var(--sans);font-weight:800;font-size:40px;line-height:1;transition:color .3s}
.price-meta{display:flex;gap:16px;margin-top:6px;font-size:11px;flex-wrap:wrap}
.price-meta span{color:var(--text2)}
.price-meta strong{color:var(--text)}

/* ── MAP CANVAS ── */
#vesselMap{width:100%;border-radius:6px;background:var(--bg3);cursor:crosshair;display:block}
.map-legend{display:flex;gap:16px;flex-wrap:wrap;margin-top:8px;font-size:10px;color:var(--text2)}
.ml-dot{width:8px;height:8px;border-radius:50%;display:inline-block;margin-right:4px;vertical-align:middle}

/* ── THREAT SYSTEM ── */
.threat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:14px}
.threat-card{background:var(--bg2);border:1px solid var(--border);border-radius:7px;padding:13px;position:relative}
.threat-level{position:absolute;top:10px;right:10px;font-size:9px;font-weight:700;padding:2px 6px;border-radius:3px}
.tl-critical{background:rgba(255,61,90,.2);color:var(--red);border:1px solid rgba(255,61,90,.4)}
.tl-high{background:rgba(245,166,35,.2);color:var(--amber);border:1px solid rgba(245,166,35,.4)}
.tl-medium{background:rgba(41,182,246,.2);color:var(--blue);border:1px solid rgba(41,182,246,.4)}
.tl-low{background:rgba(0,229,160,.2);color:var(--accent);border:1px solid rgba(0,229,160,.4)}
.threat-icon{font-size:22px;margin-bottom:6px}
.threat-title{font-family:var(--sans);font-weight:700;font-size:13px;color:#fff;margin-bottom:3px}
.threat-sub{font-size:10px;color:var(--text2);margin-bottom:8px}
.threat-impact{font-size:10px;padding:4px 0;border-top:1px solid var(--border);margin-top:6px;color:var(--text)}

/* ── MINE GRID ── */
.mine-row{display:flex;align-items:center;gap:10px;padding:7px 0;border-bottom:1px solid var(--border);font-size:11px}
.mine-row:last-child{border-bottom:none}
.mine-flag{font-size:16px;width:24px;text-align:center}
.mine-info{flex:1}
.mine-name{color:#fff;font-weight:700;font-size:11px}
.mine-detail{font-size:10px;color:var(--text2)}
.mine-output{text-align:right;font-size:10px}

/* ── DARK POOL ITEM ── */
.dp-i{display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid var(--border)}
.dp-i:last-child{border-bottom:none}
.dp-t{font-family:var(--sans);font-weight:700;color:#fff;width:55px;font-size:12px}
.dp-b{flex:1;height:4px;background:var(--bg3);border-radius:2px;overflow:hidden}
.dp-bf{height:100%;border-radius:2px}
.dp-v{width:75px;text-align:right;font-size:10px;color:var(--text2)}

/* ── PRICE HISTORY CHART ── */
.ch-wrap{position:relative}

/* ── WHALE CARDS ── */
.wg{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:14px}
.wc{background:var(--bg2);border:1px solid var(--border);border-radius:7px;padding:14px}
.we{font-size:26px;margin-bottom:6px;display:block}
.wn{font-family:var(--sans);font-weight:700;font-size:14px;color:#fff;margin-bottom:2px}
.wa{font-size:10px;color:var(--text2);margin-bottom:8px}
.wp{font-size:10px;display:flex;flex-direction:column;gap:3px}
.wp span{display:flex;justify-content:space-between;padding:3px 0;border-bottom:1px solid var(--border)}
.wp span:last-child{border-bottom:none}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:var(--bg)}::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px}

/* ── FOOTER ── */
footer{border-top:1px solid var(--border);padding-top:20px;margin-top:50px;font-size:10px;color:var(--text3);display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px}

/* ── RESPONSIVE ── */
@media(max-width:1000px){.kpi4,.kpi6{grid-template-columns:repeat(2,1fr)}.g2,.g3,.g-wide,.g-wide2{grid-template-columns:1fr}.threat-grid,.wg{grid-template-columns:1fr 1fr}}
@media(max-width:600px){.kpi4,.kpi6{grid-template-columns:1fr 1fr}.threat-grid,.wg{grid-template-columns:1fr}}

/* ── WHALE EMULATOR ── */
.we-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:16px}
.we-card{background:var(--bg2);border:1px solid var(--border);border-radius:8px;overflow:hidden;transition:border-color .2s}
.we-card:hover{border-color:var(--border2)}
.we-card.selected{border-color:var(--accent);box-shadow:0 0 0 1px rgba(0,229,160,.2)}
.we-head{padding:13px 14px 10px;border-bottom:1px solid var(--border);display:flex;align-items:flex-start;justify-content:space-between;gap:8px}
.we-name{font-family:var(--sans);font-weight:700;font-size:14px;color:#fff}
.we-style{font-size:9px;color:var(--text3);letter-spacing:.06em;text-transform:uppercase;margin-top:2px}
.we-body{padding:12px 14px}
.wr-track{height:6px;background:var(--bg3);border-radius:3px;overflow:hidden;margin:6px 0 3px}
.wr-fill{height:100%;border-radius:3px;transition:width .8s ease}
.wr-label{display:flex;justify-content:space-between;font-size:9px;color:var(--text3)}
.we-stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;margin-top:10px}
.we-stat{background:var(--bg3);padding:7px 8px;border-radius:5px;text-align:center}
.we-stat-v{font-family:var(--sans);font-weight:700;font-size:14px;color:#fff;line-height:1}
.we-stat-l{font-size:9px;color:var(--text3);margin-top:2px}
.copy-btn{width:100%;margin-top:10px;padding:7px;background:rgba(0,229,160,.1);border:1px solid rgba(0,229,160,.3);border-radius:5px;color:var(--accent);font-family:var(--mono);font-size:10px;cursor:pointer;letter-spacing:.06em;text-transform:uppercase;transition:all .18s}
.copy-btn:hover{background:rgba(0,229,160,.2);border-color:var(--accent)}
.copy-btn.active{background:var(--accent);color:#000;font-weight:700}
.trade-feed{max-height:340px;overflow-y:auto}
.tf-row{display:flex;align-items:center;gap:10px;padding:8px 10px;border-bottom:1px solid var(--border);font-size:11px;transition:background .3s}
.tf-row.new-trade{animation:tradeIn .5s ease}
@keyframes tradeIn{from{background:rgba(0,229,160,.12)}to{background:transparent}}
.tf-row.my-copy{background:rgba(0,229,160,.05);border-left:2px solid var(--accent)}
.tf-time{font-size:9px;color:var(--text3);width:50px;flex-shrink:0;font-family:var(--mono)}
.tf-whale{width:90px;font-size:10px;font-weight:700;flex-shrink:0}
.tf-asset{width:55px;font-weight:700;color:#fff;flex-shrink:0}
.tf-dir{width:40px;flex-shrink:0}
.tf-entry{width:60px;text-align:right;flex-shrink:0;color:var(--text2);font-size:10px}
.tf-size{width:60px;text-align:right;flex-shrink:0;color:var(--text2);font-size:10px}
.tf-pnl{width:65px;text-align:right;font-weight:700;font-size:11px;flex-shrink:0}
.tf-status{width:55px;text-align:right;flex-shrink:0}
.tf-copy{flex-shrink:0;margin-left:auto}
.copy-mini{padding:3px 8px;border:1px solid rgba(0,229,160,.4);background:transparent;border-radius:3px;color:var(--accent);font-size:9px;cursor:pointer;font-family:var(--mono);transition:all .15s}
.copy-mini:hover{background:rgba(0,229,160,.15)}
.copy-mini.done{border-color:var(--text3);color:var(--text3);cursor:default}
.my-pf-row{display:flex;align-items:center;gap:10px;padding:9px 10px;border-bottom:1px solid var(--border);font-size:11px}
.my-pf-row:last-child{border-bottom:none}
.pf-asset{width:60px;font-family:var(--sans);font-weight:700;color:#fff;font-size:13px}
.pf-dir{width:40px}
.pf-entry{width:65px;font-size:10px;color:var(--text2)}
.pf-current{width:65px;font-size:10px}
.pf-pnl{width:80px;font-weight:700;font-size:12px;text-align:right}
.pf-pnlpct{font-size:9px;font-weight:400}
.pf-whale{flex:1;font-size:9px;color:var(--text3)}
.pf-close{padding:3px 8px;border:1px solid rgba(255,61,90,.4);background:transparent;border-radius:3px;color:var(--red);font-size:9px;cursor:pointer;font-family:var(--mono)}
.pf-close:hover{background:rgba(255,61,90,.15)}
.score-ring{width:70px;height:70px;flex-shrink:0}
.wr-big{font-family:var(--sans);font-weight:800;font-size:32px;line-height:1}
.signal-bar{height:4px;border-radius:2px;margin-top:4px;transition:width .6s ease}
.signal-row{display:flex;align-items:center;gap:8px;margin-bottom:5px;font-size:10px}
.signal-label{width:100px;color:var(--text2);flex-shrink:0;font-size:9px}
.signal-track{flex:1;height:4px;background:var(--bg3);border-radius:2px;overflow:hidden}
.signal-fill{height:100%;border-radius:2px;transition:width .6s ease}
.pnl-counter{font-family:var(--sans);font-weight:800;font-size:28px;transition:color .3s}
.closed-row{display:flex;align-items:center;gap:8px;padding:6px 10px;border-bottom:1px solid var(--border);font-size:10px;opacity:.75}
.closed-row:last-child{border-bottom:none}
.leaderboard-row{display:flex;align-items:center;gap:12px;padding:9px 12px;border-bottom:1px solid var(--border);font-size:11px}
.leaderboard-row:last-child{border-bottom:none}
.lb-rank{width:24px;font-family:var(--sans);font-weight:800;font-size:16px;color:var(--text3);flex-shrink:0}
.lb-rank.gold-rank{color:var(--gold)}
.lb-rank.silver-rank{color:var(--silver)}
.lb-rank.bronze-rank{color:var(--crude)}
.lb-name{flex:1;font-weight:700;color:#fff}
.lb-wr{width:80px;text-align:center}
.lb-trades{width:60px;text-align:right;color:var(--text2);font-size:10px}
.lb-pnl{width:75px;text-align:right;font-weight:700}

/* ── TOOLTIP ── */
.tip{position:fixed;background:var(--bg4);border:1px solid var(--border2);border-radius:6px;padding:8px 12px;font-size:10px;color:var(--text);pointer-events:none;z-index:200;display:none;max-width:220px;line-height:1.5}

/* ── PRICE FLASH ── */
@keyframes priceUp{0%,100%{background:transparent}50%{background:rgba(0,229,160,.15)}}
@keyframes priceDn{0%,100%{background:transparent}50%{background:rgba(255,61,90,.15)}}
.flash-up{animation:priceUp .6s ease}
.flash-dn{animation:priceDn .6s ease}
</style>
</head>
<body>
<div class="tip" id="tooltip"></div>

<div class="wrap">
<!-- HEADER -->
<header>
  <div class="logo"><div class="logo-icon">ILT</div><span>ILT</span>&nbsp;Market Intelligence</div>
  <div class="header-meta">
    <div class="live-pill"><div class="live-dot"></div>LIVE FEED</div>
    <span id="hclock" style="color:var(--text2)">13 Mar 2026</span>
    <span class="update-clock">Aggiornamento tra <span id="countdown" style="color:var(--accent)">10</span>s</span>
    <span style="color:var(--text3)">ICI · WhaleStream · OPEC · USGS · MarineTraffic</span>
  </div>
</header>

<!-- LIVE TICKER STRIP -->
<div class="ticker-strip">
  <div class="ticker-inner" id="tickerInner">
    <!-- populated by JS -->
  </div>
</div>

<!-- NAV -->
<nav>
  <button class="nb active" onclick="showSec('overview',this)">Overview</button>
  <button class="nb" onclick="showSec('commodities',this)">🛢 Materie Prime</button>
  <button class="nb" onclick="showSec('volume',this)">Volume</button>
  <button class="nb" onclick="showSec('flows',this)">Flussi ETF</button>
  <button class="nb" onclick="showSec('whales',this)">🐋 Whales</button>
  <button class="nb" onclick="showSec('emulator',this)">🎯 Whale Emulator</button>
  <button class="nb" onclick="showSec('funds',this)">Fondi</button>
</nav>

