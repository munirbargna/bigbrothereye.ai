  CHOKEPOINTS.forEach(cp=>{
    const [cx,cy]=px(cp.x*360-180, 90-cp.y*180); // cp already has x/y from geo()
    // Use raw x,y since they're already normalized
    const cpx=cp.x*W, cpy=cp.y*H;
    // Pulsing ring for active threats
    if(cp.status!=='NORMALE'){
      ctx.beginPath(); ctx.arc(cpx,cpy,cp.radius+4,0,Math.PI*2);
      ctx.fillStyle=cp.color+'15'; ctx.fill();
    }
    ctx.beginPath(); ctx.arc(cpx,cpy,cp.radius,0,Math.PI*2);
    ctx.fillStyle=cp.color+'20'; ctx.fill();
    ctx.strokeStyle=cp.color; ctx.lineWidth=1.2;
    ctx.setLineDash(cp.status==='NORMALE'?[3,3]:[2,2]);
    ctx.stroke(); ctx.setLineDash([]);
    // Label — only for non-normal, with background pill
    if(cp.status!=='NORMALE'){
      const label=cp.name;
      ctx.font='bold 9px Space Mono,monospace';
      const tw=ctx.measureText(label).width;
      const lx=cpx-tw/2-4, ly=cpy-cp.radius-18;
      ctx.fillStyle='rgba(6,10,13,.82)';
      ctx.beginPath();
      ctx.roundRect ? ctx.roundRect(lx,ly,tw+8,14,3) : ctx.rect(lx,ly,tw+8,14);
      ctx.fill();
      ctx.fillStyle=cp.color;
      ctx.textAlign='center';
      ctx.fillText(label,cpx,ly+11);
    }
  });

  // ── MINES ──
  MINES_MAP.forEach(m=>{
    const [mx,my]=[m.x*W, m.y*H];
    // Diamond shape
    const s=5;
    ctx.beginPath();
    ctx.moveTo(mx, my-s); ctx.lineTo(mx+s, my); ctx.lineTo(mx, my+s); ctx.lineTo(mx-s, my);
    ctx.closePath();
    ctx.fillStyle=m.color+'99'; ctx.fill();
    ctx.strokeStyle=m.color; ctx.lineWidth=1; ctx.stroke();
    // Label with subtle background
    ctx.font='8px Space Mono,monospace';
    const tw=ctx.measureText(m.name).width;
    ctx.fillStyle='rgba(6,10,13,.75)';
    ctx.fillRect(mx-tw/2-2, my+7, tw+4, 11);
    ctx.fillStyle=m.color+'ee';
    ctx.textAlign='center';
    ctx.fillText(m.name, mx, my+17);
  });

  // ── VESSELS ──
  VESSELS.forEach(v=>{
    const vx=v.x*W, vy=v.y*H;
    const VCOL=['#ef6c00','#ffd54f','#b0bec5'];
    const col=VCOL[v.type];
    const isHov=hoveredVessel===v;
    const isBlocked=v.status==='BLOCCATA';
    const isAir=v.status==='VOLO';
    const r=isHov?7:5;

    if(isBlocked){
      ctx.beginPath(); ctx.arc(vx,vy,r+6,0,Math.PI*2);
      ctx.fillStyle='rgba(255,61,90,.12)'; ctx.fill();
    }

    if(isAir){
      // Airplane shape (small diamond + cross)
      ctx.save();
      ctx.translate(vx,vy);
      ctx.fillStyle=col+'cc';
      ctx.beginPath();
      ctx.moveTo(0,-r); ctx.lineTo(r*.5,0); ctx.lineTo(0,r*.4); ctx.lineTo(-r*.5,0);
      ctx.closePath(); ctx.fill();
      if(isHov){ ctx.strokeStyle='#fff'; ctx.lineWidth=.8; ctx.stroke(); }
      ctx.restore();
    } else {
      // Ship triangle
      ctx.beginPath();
      ctx.moveTo(vx, vy-r);
      ctx.lineTo(vx+r*.75, vy+r*.6);
      ctx.lineTo(vx-r*.75, vy+r*.6);
      ctx.closePath();
      ctx.fillStyle=isBlocked?'#ff3d5a':col;
      ctx.fill();
      if(isHov||isBlocked){ ctx.strokeStyle='#fff'; ctx.lineWidth=1; ctx.stroke(); }
    }

    // Hover tooltip tag
    if(isHov){
      ctx.font='bold 9px Space Mono,monospace';
      const lbl=`${v.id}`;
      const tw=ctx.measureText(lbl).width+10;
      ctx.fillStyle='rgba(6,10,13,.88)';
      ctx.fillRect(vx-tw/2, vy-r-18, tw, 14);
      ctx.fillStyle='#fff'; ctx.textAlign='center';
      ctx.fillText(lbl, vx, vy-r-7);
    }
  });

  // ── REGION LABELS ──
  ctx.font='8px Space Mono,monospace'; ctx.textAlign='center';
  [
    ['NORTH AMERICA',-100,48,'#2a4a5e'],
    ['SOUTH AMERICA',-58,-18,'#2a4a5e'],
    ['EUROPE',15,54,'#2a4a5e'],
    ['AFRICA',18,8,'#2a4a5e'],
    ['MIDDLE EAST',46,28,'#2a4a5e'],
    ['ASIA',90,42,'#2a4a5e'],
    ['AUSTRALIA',134,-28,'#2a4a5e'],
  ].forEach(([t,lon,lat,c])=>{
    ctx.fillStyle=c;
    const [x,y]=px(lon,lat);
    ctx.fillText(t,x,y);
  });
}

function animateMap(){
  VESSELS.forEach(v=>{
    if(v.status==='BLOCCATA') return; // blocked vessel stays put
    v.x += v.dx * (0.8 + Math.random()*.4);
    v.y += (v.dy||0) * (0.8 + Math.random()*.4);
    // Wrap longitude
    if(v.x > 1) v.x -= 1;
    if(v.x < 0) v.x += 1;
    // Clamp latitude to reasonable ocean bands (avoid poles)
    if(v.y < 0.08) v.y = 0.08;
    if(v.y > 0.88) v.y = 0.88;
  });
  drawMap();
  animFrame = requestAnimationFrame(animateMap);
}

