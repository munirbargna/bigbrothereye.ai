function rand(min,max){ return Math.random()*(max-min)+min; }
function fmtChg(v,v0,pfx='',dec=2){
  const d=v-v0, p=d/v0*100;
  const sym=d>=0?'▲':'▼';
  return {str:`${sym} ${pfx}${Math.abs(d).toFixed(dec)} (${p>=0?'+':''}${p.toFixed(2)}%)`, cls:d>=0?'up':'dn'};
}

function tickPrices(){
  // Micro random walks with realistic volatility
  STATE.sp500  += rand(-18, 12);
  STATE.ndx    += rand(-55, 40);
  STATE.vix    += rand(-0.4, 0.6);
  STATE.oil    += rand(-0.8, 1.4);
  STATE.gold   += rand(-18, 12);
  STATE.silver += rand(-0.5, 0.4);
  STATE.wti    += rand(-0.7, 1.2);

  STATE.vix    = Math.max(22, Math.min(35, STATE.vix));
  STATE.oil    = Math.max(95, Math.min(115, STATE.oil));
  STATE.gold   = Math.max(5000, Math.min(5300, STATE.gold));
  STATE.silver = Math.max(79, Math.min(90, STATE.silver));

  updateDisplay();
  updatePriceHistory();
  updateSparklines();
}

function flashEl(id, up){
  const el = document.getElementById(id);
  if(!el) return;
  el.classList.remove('flash-up','flash-dn');
  void el.offsetWidth;
  el.classList.add(up?'flash-up':'flash-dn');
  setTimeout(()=>el.classList.remove('flash-up','flash-dn'),700);
}

function setKpiVal(elId, val, formatted, chgClass){
  const el = document.getElementById(elId);
  if(!el) return;
  const prev = el.textContent;
  el.textContent = formatted;
  if(prev !== formatted) flashEl(elId.replace('v-','kpi-'), chgClass==='up');
}

