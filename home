  document.getElementById('v-gold').textContent  = '$'+fmt(STATE.gold,0);
  document.getElementById('v-silver').textContent= '$'+fmt(STATE.silver);

  // Changes
  const cSp = fmtChg(STATE.sp500,STATE.sp500_0,'',0);
  const cNd = fmtChg(STATE.ndx,STATE.ndx_0,'',0);
  const cOi = fmtChg(STATE.oil,STATE.oil_0,'$');
  const cGo = fmtChg(STATE.gold,STATE.gold_0,'$',0);
